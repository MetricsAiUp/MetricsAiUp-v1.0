generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// RBAC — Роли и права
// ==========================================

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  isActive       Boolean  @default(true) @map("is_active")
  hiddenElements String   @default("[]") @map("hidden_elements")
  pages          String   @default("[]")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  roles UserRole[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String   @map("display_name")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  key         String  @unique
  displayName String  @map("display_name")
  group       String
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ==========================================
// Зоны и Посты
// ==========================================
// ZoneType: repair, waiting, entry, parking, free
// PostType: light, heavy, special
// PostStatus: free, occupied, occupied_no_work, active_work

model Zone {
  id            String   @id @default(uuid())
  name          String
  type          String   @default("repair") // ZoneType
  description   String?
  coordinates   String?  // JSON полигон зоны на карте
  isActive      Boolean  @default(true) @map("is_active")
  // Map sync (auto-propagation from MapLayout)
  displayName   String?  @map("display_name")
  displayNameEn String?  @map("display_name_en")
  deleted       Boolean  @default(false)
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  posts     Post[]
  stays     ZoneStay[]
  events    Event[]
  cameras   CameraZone[]
  recommendations Recommendation[]

  @@index([isActive])
  @@index([deleted])
  @@map("zones")
}

model Post {
  id          String  @id @default(uuid())
  zoneId      String  @map("zone_id")
  name        String
  type        String  @default("light") // PostType
  status      String  @default("free")  // PostStatus
  coordinates String? // JSON позиция поста на карте
  isActive    Boolean @default(true) @map("is_active")
  // Map sync (auto-propagation from MapLayout)
  number           Int?      @unique                    // стабильный ключ синка с картой
  displayName      String?   @map("display_name")        // "Пост 4 — легковое"
  displayNameEn    String?   @map("display_name_en")     // "Post 4 — light vehicles"
  externalZoneName String?   @map("external_zone_name")  // имя зоны во внешнем CV API
  externalAliases  String?   @map("external_aliases")    // JSON-массив доп. имён
  deleted          Boolean   @default(false)
  deletedAt        DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  zone   Zone        @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  stays  PostStay[]
  events Event[]
  recommendations Recommendation[]

  @@index([isActive])
  @@index([zoneId])
  @@index([deleted])
  @@map("posts")
}

// ==========================================
// Камеры
// ==========================================

model Camera {
  id       String  @id @default(uuid())
  name     String
  rtspUrl  String  @map("rtsp_url")
  isActive Boolean @default(true) @map("is_active")
  // Map sync (auto-propagation from MapLayout)
  deleted   Boolean   @default(false)
  deletedAt DateTime? @map("deleted_at")

  zones  CameraZone[]
  events Event[]

  @@index([deleted])
  @@map("cameras")
}

model CameraZone {
  cameraId String @map("camera_id")
  zoneId   String @map("zone_id")
  priority Int    @default(0)

  camera Camera @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  zone   Zone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@id([cameraId, zoneId])
  @@map("camera_zones")
}

// ==========================================
// Сессии авто
// ==========================================
// VehicleSessionStatus: active, completed

model VehicleSession {
  id            String    @id @default(uuid())
  plateNumber   String?   @map("plate_number")
  entryTime     DateTime  @default(now()) @map("entry_time")
  exitTime      DateTime? @map("exit_time")
  status        String    @default("active") // VehicleSessionStatus
  trackId       String?   @map("track_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  zoneStays      ZoneStay[]
  postStays      PostStay[]
  events         Event[]
  workOrderLinks WorkOrderLink[]

  @@index([status])
  @@index([trackId, status])
  @@map("vehicle_sessions")
}

// ==========================================
// Пребывание в зонах и на постах
// ==========================================

model ZoneStay {
  id               String    @id @default(uuid())
  zoneId           String    @map("zone_id")
  vehicleSessionId String    @map("vehicle_session_id")
  entryTime        DateTime  @default(now()) @map("entry_time")
  exitTime         DateTime? @map("exit_time")
  duration         Int?

  zone           Zone           @relation(fields: [zoneId], references: [id])
  vehicleSession VehicleSession @relation(fields: [vehicleSessionId], references: [id])

  @@map("zone_stays")
}

model PostStay {
  id               String    @id @default(uuid())
  postId           String    @map("post_id")
  vehicleSessionId String    @map("vehicle_session_id")
  startTime        DateTime  @default(now()) @map("start_time")
  endTime          DateTime? @map("end_time")
  hasWorker        Boolean   @default(false) @map("has_worker")
  isActive         Boolean   @default(false) @map("is_active")
  activeTime       Int       @default(0) @map("active_time")
  idleTime         Int       @default(0) @map("idle_time")

  post           Post           @relation(fields: [postId], references: [id])
  vehicleSession VehicleSession @relation(fields: [vehicleSessionId], references: [id])
  workOrderLinks WorkOrderLink[]

  @@index([vehicleSessionId, endTime])
  @@index([postId, endTime])
  @@map("post_stays")
}

// ==========================================
// События от CV
// ==========================================
// EventType: vehicle_entered_zone, vehicle_left_zone, vehicle_moving,
//   vehicle_waiting, post_occupied, post_vacated, worker_present,
//   worker_absent, work_activity, work_idle

model Event {
  id               String    @id @default(uuid())
  type             String    // EventType
  zoneId           String    @map("zone_id")
  postId           String?   @map("post_id")
  vehicleSessionId String?   @map("vehicle_session_id")
  cameraId         String?   @map("camera_id")
  cameraSources    String    @default("[]") @map("camera_sources") // JSON array
  confidence       Float     @default(0)
  startTime        DateTime  @default(now()) @map("start_time")
  endTime          DateTime? @map("end_time")
  rawData          String?   @map("raw_data") // JSON
  createdAt        DateTime  @default(now()) @map("created_at")

  zone           Zone            @relation(fields: [zoneId], references: [id])
  post           Post?           @relation(fields: [postId], references: [id])
  vehicleSession VehicleSession? @relation(fields: [vehicleSessionId], references: [id])
  camera         Camera?         @relation(fields: [cameraId], references: [id])

  @@index([type])
  @@index([zoneId])
  @@index([createdAt])
  @@map("events")
}

// ==========================================
// Заказ-наряды (1С)
// ==========================================
// WorkOrderStatus: scheduled, in_progress, completed, cancelled, no_show

model WorkOrder {
  id            String    @id @default(uuid())
  externalId    String?   @unique @map("external_id")
  orderNumber   String    @map("order_number")
  scheduledTime DateTime  @map("scheduled_time")
  status        String    @default("scheduled") // WorkOrderStatus
  plateNumber   String?   @map("plate_number")
  workType      String?   @map("work_type")
  normHours     Float?    @map("norm_hours")
  actualHours   Float?    @map("actual_hours")
  brand         String?
  model         String?
  worker        String?
  master        String?
  postNumber    Int?      @map("post_number")
  startTime     DateTime? @map("start_time")
  endTime       DateTime? @map("end_time")
  estimatedEnd  DateTime? @map("estimated_end")
  pausedAt       DateTime? @map("paused_at")
  totalPausedMs  Int       @default(0) @map("total_paused_ms")
  version        Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  links WorkOrderLink[]

  @@index([postNumber])
  @@index([status])
  @@index([status, scheduledTime])
  @@index([scheduledTime])
  @@map("work_orders")
}

model WorkOrderLink {
  id               String  @id @default(uuid())
  vehicleSessionId String  @map("vehicle_session_id")
  postStayId       String? @map("post_stay_id")
  workOrderId      String  @map("work_order_id")
  confidence       Float   @default(0)
  matchType        String  @map("match_type")

  vehicleSession VehicleSession @relation(fields: [vehicleSessionId], references: [id])
  postStay       PostStay?      @relation(fields: [postStayId], references: [id])
  workOrder      WorkOrder      @relation(fields: [workOrderId], references: [id])

  @@map("work_order_links")
}

// ==========================================
// Рекомендации
// ==========================================
// RecommendationType: no_show, post_free, capacity_available, work_overtime, vehicle_idle
// RecommendationStatus: active, acknowledged, resolved

model Recommendation {
  id        String   @id @default(uuid())
  type      String   // RecommendationType
  zoneId    String?  @map("zone_id")
  postId    String?  @map("post_id")
  message   String   // RU text
  messageEn String?  @map("message_en") // EN text
  status    String   @default("active") // RecommendationStatus
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  zone Zone? @relation(fields: [zoneId], references: [id])
  post Post? @relation(fields: [postId], references: [id])

  @@index([status])
  @@index([type, zoneId, postId, status])
  @@map("recommendations")
}

// ==========================================
// Логи синхронизации 1С
// ==========================================

model SyncLog {
  id        String   @id @default(uuid())
  type      String   // "import" or "export"
  source    String   // "manual", "auto", "api"
  filename  String?
  status    String   @default("pending") // pending, success, error
  records   Int      @default(0)  // number of records processed
  errors    Int      @default(0)  // number of errors
  details   String?  // JSON string with details/errors
  createdAt DateTime @default(now()) @map("created_at")

  @@map("sync_logs")
}

// ==========================================
// Map Layout (STO floor plan editor)
// ==========================================
model MapLayout {
  id        String   @id @default(uuid())
  name      String
  width     Float    @default(46540) // mm
  height    Float    @default(30690) // mm
  bgImage   String?  // path to background image
  elements  String   @default("[]") // JSON array of map elements
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions MapLayoutVersion[]

  @@map("map_layouts")
}

model MapLayoutVersion {
  id          String   @id @default(uuid())
  layoutId    String   @map("layout_id")
  version     Int
  name        String
  width       Float
  height      Float
  bgImage     String?
  elements    String   @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")

  layout MapLayout @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@unique([layoutId, version])
  @@map("map_layout_versions")
}

// ==========================================
// Смены (Shifts)
// ==========================================

model Shift {
  id          String   @id @default(uuid())
  name        String
  date        DateTime
  startTime   String   @map("start_time")   // "08:00"
  endTime     String   @map("end_time")     // "20:00"
  status      String   @default("planned")  // planned, active, completed
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  workers     ShiftWorker[]

  @@map("shifts")
}

// ==========================================
// Аудит-лог
// ==========================================

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  userName  String?  @map("user_name")
  action    String   // "create", "update", "delete"
  entity    String   // "user", "zone", "post", "workOrder", etc.
  entityId  String?  @map("entity_id")
  oldData   String?  @map("old_data")  // JSON
  newData   String?  @map("new_data")  // JSON
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==========================================
// Фото фиксаци��
// ==========================================

model Photo {
  id               String   @id @default(uuid())
  sessionId        String?  @map("session_id")
  workOrderId      String?  @map("work_order_id")
  path             String
  filename         String
  mimeType         String   @default("image/jpeg") @map("mime_type")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([workOrderId])
  @@map("photos")
}

// ==========================================
// Push-подписки (PWA)
// ==========================================

model PushSubscription {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  endpoint   String   @unique
  keys       String   // JSON {p256dh, auth}
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("push_subscriptions")
}

// ==========================================
// Мультитенантность — Филиалы
// ==========================================

model Location {
  id        String   @id @default(uuid())
  name      String
  address   String?
  timezone  String   @default("Europe/Moscow")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("locations")
}

// ==========================================
// Telegram привязка
// ==========================================

model TelegramLink {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  chatId    String   @map("chat_id")
  username  String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("telegram_links")
}

// ==========================================
// Расписание отчётов
// ==========================================

model ReportSchedule {
  id        String    @id @default(uuid())
  name      String
  frequency String    // "daily" | "weekly"
  dayOfWeek Int?      @map("day_of_week")
  hour      Int       @default(20)
  minute    Int       @default(0)
  format    String    @default("xlsx")
  chatId    String?   @map("chat_id")
  isActive  Boolean   @default(true) @map("is_active")
  lastRunAt DateTime? @map("last_run_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("report_schedules")
}

// ==========================================
// Снимки мониторинга (накопление истории)
// ==========================================

model MonitoringSnapshot {
  id               String   @id @default(uuid())
  zoneName         String   @map("zone_name")
  externalType     String?  @map("external_type") // "lift" | "other"
  status           String   // "free" | "occupied"
  plateNumber      String?  @map("plate_number")
  carColor         String?  @map("car_color")
  carModel         String?  @map("car_model")
  carMake          String?  @map("car_make")
  carBody          String?  @map("car_body")
  carFirstSeen     DateTime? @map("car_first_seen")
  worksInProgress  Boolean  @default(false) @map("works_in_progress")
  worksDescription String?  @map("works_description")
  peopleCount      Int      @default(0) @map("people_count")
  openParts        String?  @map("open_parts") // JSON array as string (SQLite)
  confidence       String?
  externalUpdate   DateTime? @map("external_update") // lastUpdate from external API
  timestamp        DateTime @default(now())

  @@index([zoneName, timestamp])
  @@index([timestamp])
  @@map("monitoring_snapshots")
}

// Текущее (последнее) состояние зоны/поста — обновляется на каждый poll внешнего API.
// Источник истины для live-режима. Кэш в памяти monitoringProxy — проекция этой таблицы.
model MonitoringCurrent {
  zoneName         String   @id @map("zone_name")
  externalType     String?  @map("external_type")
  status           String
  plateNumber      String?  @map("plate_number")
  carColor         String?  @map("car_color")
  carModel         String?  @map("car_model")
  carMake          String?  @map("car_make")
  carBody          String?  @map("car_body")
  carFirstSeen     DateTime? @map("car_first_seen")
  worksInProgress  Boolean  @default(false) @map("works_in_progress")
  worksDescription String?  @map("works_description")
  peopleCount      Int      @default(0) @map("people_count")
  openParts        String?  @map("open_parts")
  confidence       String?
  externalUpdate   DateTime? @map("external_update")
  fetchedAt        DateTime @default(now()) @map("fetched_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("monitoring_current")
}

model ShiftWorker {
  id        String @id @default(uuid())
  shiftId   String @map("shift_id")
  name      String
  role      String  // "mechanic", "master", "diagnostician"
  postId    String? @map("post_id")  // assigned post
  shift     Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@map("shift_workers")
}
