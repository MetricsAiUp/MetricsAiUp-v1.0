generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// RBAC — Роли и права
// ==========================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roles UserRole[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String   @map("display_name")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  key         String  @unique
  displayName String  @map("display_name")
  group       String
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ==========================================
// Зоны и Посты
// ==========================================
// ZoneType: repair, waiting, entry, parking, free
// PostType: light, heavy, special
// PostStatus: free, occupied, occupied_no_work, active_work

model Zone {
  id          String   @id @default(uuid())
  name        String
  type        String   @default("repair") // ZoneType
  description String?
  coordinates String?  // JSON полигон зоны на карте
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  posts     Post[]
  stays     ZoneStay[]
  events    Event[]
  cameras   CameraZone[]
  recommendations Recommendation[]

  @@map("zones")
}

model Post {
  id          String  @id @default(uuid())
  zoneId      String  @map("zone_id")
  name        String
  type        String  @default("light") // PostType
  status      String  @default("free")  // PostStatus
  coordinates String? // JSON позиция поста на карте
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  zone   Zone        @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  stays  PostStay[]
  events Event[]
  recommendations Recommendation[]

  @@map("posts")
}

// ==========================================
// Камеры
// ==========================================

model Camera {
  id       String  @id @default(uuid())
  name     String
  rtspUrl  String  @map("rtsp_url")
  isActive Boolean @default(true) @map("is_active")

  zones  CameraZone[]
  events Event[]

  @@map("cameras")
}

model CameraZone {
  cameraId String @map("camera_id")
  zoneId   String @map("zone_id")
  priority Int    @default(0)

  camera Camera @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  zone   Zone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@id([cameraId, zoneId])
  @@map("camera_zones")
}

// ==========================================
// Сессии авто
// ==========================================
// VehicleSessionStatus: active, completed

model VehicleSession {
  id            String    @id @default(uuid())
  plateNumber   String?   @map("plate_number")
  entryTime     DateTime  @default(now()) @map("entry_time")
  exitTime      DateTime? @map("exit_time")
  status        String    @default("active") // VehicleSessionStatus
  trackId       String?   @map("track_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  zoneStays      ZoneStay[]
  postStays      PostStay[]
  events         Event[]
  workOrderLinks WorkOrderLink[]

  @@map("vehicle_sessions")
}

// ==========================================
// Пребывание в зонах и на постах
// ==========================================

model ZoneStay {
  id               String    @id @default(uuid())
  zoneId           String    @map("zone_id")
  vehicleSessionId String    @map("vehicle_session_id")
  entryTime        DateTime  @default(now()) @map("entry_time")
  exitTime         DateTime? @map("exit_time")
  duration         Int?

  zone           Zone           @relation(fields: [zoneId], references: [id])
  vehicleSession VehicleSession @relation(fields: [vehicleSessionId], references: [id])

  @@map("zone_stays")
}

model PostStay {
  id               String    @id @default(uuid())
  postId           String    @map("post_id")
  vehicleSessionId String    @map("vehicle_session_id")
  startTime        DateTime  @default(now()) @map("start_time")
  endTime          DateTime? @map("end_time")
  hasWorker        Boolean   @default(false) @map("has_worker")
  isActive         Boolean   @default(false) @map("is_active")
  activeTime       Int       @default(0) @map("active_time")
  idleTime         Int       @default(0) @map("idle_time")

  post           Post           @relation(fields: [postId], references: [id])
  vehicleSession VehicleSession @relation(fields: [vehicleSessionId], references: [id])
  workOrderLinks WorkOrderLink[]

  @@map("post_stays")
}

// ==========================================
// События от CV
// ==========================================
// EventType: vehicle_entered_zone, vehicle_left_zone, vehicle_moving,
//   vehicle_waiting, post_occupied, post_vacated, worker_present,
//   worker_absent, work_activity, work_idle

model Event {
  id               String    @id @default(uuid())
  type             String    // EventType
  zoneId           String    @map("zone_id")
  postId           String?   @map("post_id")
  vehicleSessionId String?   @map("vehicle_session_id")
  cameraId         String?   @map("camera_id")
  cameraSources    String    @default("[]") @map("camera_sources") // JSON array
  confidence       Float     @default(0)
  startTime        DateTime  @default(now()) @map("start_time")
  endTime          DateTime? @map("end_time")
  rawData          String?   @map("raw_data") // JSON
  createdAt        DateTime  @default(now()) @map("created_at")

  zone           Zone            @relation(fields: [zoneId], references: [id])
  post           Post?           @relation(fields: [postId], references: [id])
  vehicleSession VehicleSession? @relation(fields: [vehicleSessionId], references: [id])
  camera         Camera?         @relation(fields: [cameraId], references: [id])

  @@index([type])
  @@index([zoneId])
  @@index([createdAt])
  @@map("events")
}

// ==========================================
// Заказ-наряды (1С)
// ==========================================
// WorkOrderStatus: scheduled, in_progress, completed, cancelled, no_show

model WorkOrder {
  id            String   @id @default(uuid())
  externalId    String?  @unique @map("external_id")
  orderNumber   String   @map("order_number")
  scheduledTime DateTime @map("scheduled_time")
  status        String   @default("scheduled") // WorkOrderStatus
  plateNumber   String?  @map("plate_number")
  workType      String?  @map("work_type")
  normHours     Float?   @map("norm_hours")
  actualHours   Float?   @map("actual_hours")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  links WorkOrderLink[]

  @@map("work_orders")
}

model WorkOrderLink {
  id               String  @id @default(uuid())
  vehicleSessionId String  @map("vehicle_session_id")
  postStayId       String? @map("post_stay_id")
  workOrderId      String  @map("work_order_id")
  confidence       Float   @default(0)
  matchType        String  @map("match_type")

  vehicleSession VehicleSession @relation(fields: [vehicleSessionId], references: [id])
  postStay       PostStay?      @relation(fields: [postStayId], references: [id])
  workOrder      WorkOrder      @relation(fields: [workOrderId], references: [id])

  @@map("work_order_links")
}

// ==========================================
// Рекомендации
// ==========================================
// RecommendationType: no_show, post_free, capacity_available, work_overtime, vehicle_idle
// RecommendationStatus: active, acknowledged, resolved

model Recommendation {
  id        String   @id @default(uuid())
  type      String   // RecommendationType
  zoneId    String?  @map("zone_id")
  postId    String?  @map("post_id")
  message   String   // RU text
  messageEn String?  @map("message_en") // EN text
  status    String   @default("active") // RecommendationStatus
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  zone Zone? @relation(fields: [zoneId], references: [id])
  post Post? @relation(fields: [postId], references: [id])

  @@map("recommendations")
}
